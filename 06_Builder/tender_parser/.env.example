# Пример файла конфигурации .env
# Скопируйте в .env и отредактируйте при необходимости

# Режим браузера (true/false)
HEADLESS=true

# Таймауты (миллисекунды)
TIMEOUT_MS=30000

# Параметры retry
RETRY_ATTEMPTS=3
RETRY_DELAY_SEC=2

# Лимит тендеров по умолчанию
DEFAULT_LIMIT=50

# Минимальная НМЦ (рубли)
MIN_NMC_RUB=60000

# Путь к БД
DB_PATH=tenders.db

# URL базы
ZAKUPKI_BASE_URL=https://www.zakupki.gov.ru
